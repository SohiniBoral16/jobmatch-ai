# ============================================================
# JobMatch AI — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file — it contains secrets.
# ============================================================


# ============================================================
# LLM Provider — choose "openai" or "claude"
# ============================================================
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Claude (optional backup) — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5


# ============================================================
# Scraper Settings
# ============================================================
HOURS_OLD=24                # Only show jobs posted in last N hours
RESULTS_PER_SEARCH=15       # Max results per query per site


# ============================================================
# Phase 2 — Email Alerts
# ============================================================
# Gmail setup:
#   1. Enable 2-Step Verification on Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" and paste below

EMAIL_SENDER=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Default recipient (can also be entered from the UI)
# EMAIL_RECIPIENT=recipient@example.com


# ============================================================
# Phase 2 — Daily Scheduler
# ============================================================
ALERT_HOUR=7
ALERT_MINUTE=0
ALERT_TIMEZONE=Asia/Kolkata
ALERT_LOCATION=Bangalore, India
# ALERT_SEARCH_TERM=
# ALERT_WORK_MODE=remote
# ALERT_EXPERIENCE_LEVEL=senior


# ============================================================
# Phase 2 — Auto-fill Candidate Details
# ============================================================
# CANDIDATE_NAME=Your Name
# CANDIDATE_EMAIL=your@email.com
# CANDIDATE_PHONE=+91 00000 00000
# CANDIDATE_LINKEDIN=https://linkedin.com/in/yourusername
# CANDIDATE_LOCATION=Bangalore, India


# ============================================================
# Phase 2 — LangSmith Observability (optional)
# ============================================================
# Get key: https://smith.langchain.com/
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_PROJECT=jobmatch-ai
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
